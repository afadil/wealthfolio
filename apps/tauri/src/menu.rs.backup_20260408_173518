use tauri::menu::{Menu, MenuBuilder, MenuItemBuilder, PredefinedMenuItem, SubmenuBuilder};
use tauri::{AppHandle, Emitter, Manager, Runtime};
use tauri_plugin_dialog::DialogExt;

pub fn create_menu<R: Runtime>(app: &AppHandle<R>) -> Result<Menu<R>, tauri::Error> {
    let app_menu = SubmenuBuilder::new(app, "Wealthfolio")
        .item(&MenuItemBuilder::with_id("open_settings", "Einstellungen...").build(app)?)
        .separator()
        .item(&PredefinedMenuItem::hide(app, Some("Ausblenden")).unwrap())
        .item(&PredefinedMenuItem::hide_others(app, Some("Andere ausblenden")).unwrap())
        .item(&PredefinedMenuItem::show_all(app, Some("Alle einblenden")).unwrap())
        .separator()
        .item(&PredefinedMenuItem::quit(app, Some("Beenden"))?)
        .build()?;

    let edit_menu = SubmenuBuilder::new(app, "Bearbeiten")
        .item(&PredefinedMenuItem::undo(app, Some("Rückgängig")).unwrap())
        .item(&PredefinedMenuItem::redo(app, Some("Wiederholen")).unwrap())
        .separator()
        .item(&PredefinedMenuItem::cut(app, Some("Ausschneiden")).unwrap())
        .item(&PredefinedMenuItem::copy(app, Some("Kopieren")).unwrap())
        .item(&PredefinedMenuItem::paste(app, Some("Einfügen")).unwrap())
        .item(&PredefinedMenuItem::select_all(app, Some("Alles auswählen")).unwrap())
        .build()?;

    let view_menu = SubmenuBuilder::new(app, "Sicht")
        .item(
            &MenuItemBuilder::with_id("toggle_fullscreen", "Vollbildmodus")
                .accelerator("F11")
                .build(app)?,
        )
        .build()?;

    let help_menu = SubmenuBuilder::new(app, "Hilfe")
        .item(&MenuItemBuilder::with_id("report_issue", "Problem melden").build(app)?)
        .separator()
        // Add the new menu item for checking updates
        .item(&MenuItemBuilder::with_id("check_for_update", "Auf Aktualisierung prüfen").build(app)?)
        .separator()
        .item(&MenuItemBuilder::with_id("show_about_dialog", "Über Wealthfolio").build(app)?)
        .build()?;

    let menu = MenuBuilder::new(app)
        .item(&app_menu)
        .item(&edit_menu)
        .item(&view_menu)
        .item(&help_menu)
        .build()?;

    Ok(menu)
}

pub fn handle_menu_event(app: &AppHandle, instance_id: &str, event_id: &str) {
    match event_id {
        "open_settings" => {
            if let Some(window) = app.get_webview_window("main") {
                let payload = serde_json::json!({ "route": "/settings/general" });
                let _ = window.emit("navigate-to-route", payload);
            }
        }
        "report_issue" => {
            app.dialog()
                .message("Sollten Sie auf Probleme stoßen, senden Sie uns bitte eine E-Mail an support@wealthfolio.app.")
                .title("Problem melden")
                .show(|_| {});
        }
        "toggle_fullscreen" => {
            if let Some(window) = app.get_webview_window("main") {
                if let Ok(is_fullscreen) = window.is_fullscreen() {
                    let _ = window.set_fullscreen(!is_fullscreen);
                } else {
                    // if getting fullscreen state fails just try toggling
                    let _ = window.set_fullscreen(false);
                }
            }
        }
        "check_for_update" => {
            let app_handle = app.clone();
            let instance_id = instance_id.to_string();
            tauri::async_runtime::spawn(async move {
                match crate::updater::check_for_update(app_handle.clone(), &instance_id).await {
                    Ok(Some(update_info)) => {
                        // Update available - emit event for frontend to show dialog
                        let _ = app_handle.emit("app:update-available", &update_info);
                    }
                    Ok(None) => {
                        // Already up-to-date - show native dialog
                        app_handle
                            .dialog()
                            .message("Sie verwenden bereits die neueste Version von Wealthfolio.")
                            .title("Keine Aktualisierungen verfügbar")
                            .show(|_| {});
                    }
                    Err(e) => {
                        // Error - show native dialog
                        app_handle
                            .dialog()
                            .message(format!("Fehler beim Prüfen auf Aktualisierungen: {}", e))
                            .title("Aktualisierungsprüfung fehlgeschlagen")
                            .show(|_| {});
                    }
                }
            });
        }
        "show_about_dialog" => {
            let package_info = app.package_info();
            let app_name = &package_info.name;
            let app_version = &package_info.version.to_string();
            let message = format!("{} version {}", app_name, app_version);
            app.dialog()
                .message(message)
                .title(format!("Um {}", app_name))
                .show(|_| {});
        }
        _ => {}
    }
}
